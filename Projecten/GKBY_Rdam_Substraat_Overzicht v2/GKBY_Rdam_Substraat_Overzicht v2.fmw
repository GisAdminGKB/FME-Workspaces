MECALC_1_ADD_INTERVAL" eq "DATETIMECALC_4_EXPRESSION" } {       set result_attr {<Unused>};       set expression {<Unused>};    };    puts "MACRO DateTimeCalculator_2_EXPRESSION $expression";    puts "MACRO DateTimeCalculator_2_RESULT_ATTR $result_attr"; ]

#! <SUBDOCUMENT
#!   NAME="UniqueValueLogger"
#!   ARCGIS_COMPATIBILITY="ARCGIS_AUTO"
#!   CATEGORY="Workflows"
#!   DESCRIPTION="&lt;p&gt;This transformer lists all unique values for a chosen attribute, along with a count of the number of occurrences for each value. The information is logged in both the Translation Window/Workspace log file and stored in attributes.&lt;/p&gt;&#10;&lt;p&gt;This transformer is useful when creating a workspace, and you need to know the possible values to use in a filter. &lt;/p&gt;"
#!   DOC_DYNAMIC_INPUT_ATTRS="0"
#!   DOC_EXTENTS="4333.87 1352.34"
#!   DOC_TOP_LEFT="2231.25 -1969.05"
#!   FME_DOCUMENT_GUID=""
#!   FME_DOCUMENT_PRIORGUID="f2857bdb-40b3-4601-bbd6-882f04c2fd1f,a10b1a62-9bbb-4cc4-8a40-799821b23ac3,3a2147ec-5054-4b98-b471-027fb125c4e2"
#!   FME_NAMES_ENCODING="windows-1252"
#!   FME_PROCESS_COUNT="NO_PARALLELISM"
#!   FME_PROCESS_GROUPS_ORDERED="No"
#!   FME_PROCESS_GROUP_BY=""
#!   FME_PROCESS_PRESERVE_GROUP_ATTR="No"
#!   FMX_ATTRIBUTE_PROPOGATION_MODE="AUTO"
#!   HISTORY="2012-01-31,Aaron&lt;space&gt;Koning,Created,2013-08-01,Arash&lt;space&gt;Ouji,Made&lt;space&gt;CSV&lt;space&gt;friendly&lt;space&gt;again,2016-02-25,Rylan&lt;space&gt;Maschak,Updated&lt;space&gt;for&lt;space&gt;FME&lt;space&gt;Hub.&lt;space&gt;Added&lt;space&gt;Output&lt;space&gt;port.,2019-07-30,Holly&lt;space&gt;Coxon,Updated&lt;space&gt;to&lt;space&gt;2019.1&lt;space&gt;for&lt;space&gt;FME&lt;space&gt;Hub.,2026-02-03,Tandra&lt;space&gt;Geraedts,Updated&lt;space&gt;to&lt;space&gt;2025.1&lt;space&gt;for&lt;space&gt;FME&lt;space&gt;Hub."
#!   IS_VISIBLE="false"
#!   LAST_SAVE_BUILD="FME(R) 2025.1.0.0 (20250704 - Build 25606 - WIN64)"
#!   LAST_SAVE_DATE="2026-02-03T09:20:40"
#!   MARKDOWN_DESCRIPTION="This transformer lists all unique values for a chosen attribute, along with a count of the number of occurrences for each value. The information is logged in both the Translation Window/Workspace log file and stored in attributes.&#10;&#10;This transformer is useful when creating a workspace, and you need to know the possible values to use in a filter. &#10;"
#!   MARKDOWN_USAGE="### Input Ports&#10;&#10;Input: This transformer accepts any features with an attribute.&#10;&#10;### Output Ports &#10;&#10;Output: Features are output with the attribute selected as the unique value to filter, and a new attribute containing the number of occurrences of each unique value. All other attributes are removed. &#10;&#10;- _count: Number of occurrences of each unique value.&#10;- _value: Unique values of selected attribute.&#10;&#10;### Parameters&#10;&#10;Attribute to Analyze: Select the attribute for the transformer to run analysis on. &#10;&#10;### Notes&#10;&#10;#### Transformer alternatives: &#10;- Duplicate Filter - Consider using this transformer if you are looking to get a list of unique values and do not need a _count attribute &#10;- StatisticsCalculator - Setting the Group By mode to the attribute to analyze will produce the same result as this transformer. It may be useful if you would like to gather other statistics, as well as the count of the unique attributes. "
#!   PYTHON_COMPATIBILITY=""
#!   REPLACED_BY=""
#!   SUPPRESS_UPGRADE="false"
#!   TITLE="UniqueValueLogger"
#!   USAGE="&lt;h3 id=&quot;input-ports&quot;&gt;Input Ports&lt;/h3&gt;&#10;&lt;p&gt;Input: This transformer accepts any features with an attribute.&lt;/p&gt;&#10;&lt;h3 id=&quot;output-ports&quot;&gt;Output Ports&lt;/h3&gt;&#10;&lt;p&gt;Output: Features are output with the attribute selected as the unique value to filter, and a new attribute containing the number of occurrences of each unique value. All other attributes are removed. &lt;/p&gt;&#10;&lt;ul&gt;&#10;&lt;li&gt;_count: Number of occurrences of each unique value.&lt;/li&gt;&#10;&lt;li&gt;_value: Unique values of selected attribute.&lt;/li&gt;&#10;&lt;/ul&gt;&#10;&lt;h3 id=&quot;parameters&quot;&gt;Parameters&lt;/h3&gt;&#10;&lt;p&gt;Attribute to Analyze: Select the attribute for the transformer to run analysis on. &lt;/p&gt;&#10;&lt;h3 id=&quot;notes&quot;&gt;Notes&lt;/h3&gt;&#10;&lt;h4&gt;Transformer alternatives:&lt;/h4&gt;&#10;&lt;ul&gt;&#10;&lt;li&gt;Duplicate Filter - Consider using this transformer if you are looking to get a list of unique values and do not need a _count attribute &lt;/li&gt;&#10;&lt;li&gt;StatisticsCalculator - Setting the Group By mode to the attribute to analyze will produce the same result as this transformer. It may be useful if you would like to gather other statistics, as well as the count of the unique attributes. &lt;/li&gt;&#10;&lt;/ul&gt;"
#!   USE_MARKDOWN="YES"
#!   VIEW_POSITION="0 -59.3756"
#!   XFORM_DEPRECATED="No"
#!   ZOOM_SCALE="100"

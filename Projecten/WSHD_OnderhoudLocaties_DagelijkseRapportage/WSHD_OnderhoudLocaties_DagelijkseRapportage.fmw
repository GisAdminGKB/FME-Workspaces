# -------------------------------------------------------------------------
# This is just a simple delay, which is given a # of seconds to stall
Tcl2 proc $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_delay {seconds unused} {     after [expr round($seconds * 1000)]; }
Tcl2 set $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_clockMillisecondsWhenLastFeatureWentBy [clock clicks -milliseconds];
# This proc ensures that no more than some maximum number of features get through each second
Tcl2 proc $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_maxpersecond {unused maxFeaturesPerSecond} {     global $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_clockMillisecondsWhenLastFeatureWentBy;     set minimumDelayInMilliseconds [expr 1000.0 / $maxFeaturesPerSecond];     set clockMillisecondsNow [clock clicks -milliseconds];     set milliSecondsSinceLastFeature [expr $clockMillisecondsNow -                    [set $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_clockMillisecondsWhenLastFeatureWentBy]];     if {$milliSecondsSinceLastFeature < $minimumDelayInMilliseconds} {         after [expr round($minimumDelayInMilliseconds - $milliSecondsSinceLastFeature)];     };     set $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_clockMillisecondsWhenLastFeatureWentBy [clock clicks -milliseconds]; }
# Now set up which of the above two delay procedures we'll actually
# use by renaming the one we want to "$(JobStatusLooper_WORKSPACE_NAME)_Decelerator_Waiter"
# Then that is what we'll actually call when a feature goes by.
Tcl2 if { {Per Feature Delay} == {Per Feature Delay} } {         rename $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_delay $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_Waiter;      } else {         rename $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_maxpersecond $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_Waiter;      };
INCLUDE [    if { ( {Per Feature Delay} == {Per Feature Delay} ) && ( {1} == {0} ) } {       puts {MACRO $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_SPLITTER_OUTPUT "$(JobStatusLooper_WORKSPACE_NAME)_Decelerator_OUTPUT" };    } else {       puts {MACRO $(JobStatusLooper_WORKSPACE_NAME)_Decelerator_SPLITTER_OUTPUT $(JobStatusLooper_WORKSPACE_NAME)_Decelerator__toDelayRejector__};    } ]

DEFAULT_MACRO StringConcatenator_tabel_met_header_1d6a8b86_6a5f_4bec_af59_bccc1cf4b32b1_ATTRS_TO_EVALUATE
INCLUDE [    if {{OUTGOING} == {OUTGOING}} {       if {[string length {_result}] == 0} { return; };       set attrs [list {_result}];    } else {       set attrs [split {<Unused>} { }];    };    set clauses {};    foreach attr $attrs {       lappend clauses "ATTR";       lappend clauses "{";       lappend clauses $attr;       lappend clauses {"<lt>table<space>border=<backslash><quote>1<backslash><quote><gt><lt>thead<gt><lt>td<gt>Inspectiedatum<lt><solidus>td<gt><lt>td<gt>Functie<lt><solidus>td<gt><lt>td<gt>Locatie<lt><solidus>td<gt><lt>td<gt>Deurnummer<lt><solidus>td<gt><lt>td<gt>Deurtype<lt><solidus>td<gt><lt>td<gt>Uitslag<lt><solidus>td<gt><lt>td<gt>Opmerking<lt><solidus>td<gt><lt><solidus>thead<gt><lt>tbody<gt><at>Value<openparen>_result<closeparen><lt><solidus>tbody<gt><lt><solidus>table<gt>"};       lappend clauses "}";    };    puts "MACRO StringConcatenator_tabel_met_header_1d6a8b86_6a5f_4bec_af59_bccc1cf4b32b1_ATTRS_TO_EVALUATE [join $clauses { }]"; ]

# -------------------------------------------------------------------------
# Create a FME_UUID_SAFE from the FME_UUID so we can use it for Tcl identifiers (FMEDESKTOP-11308)
INCLUDE [ FME_CleanseFMEUUID {$(UniqueValueLogger_WORKSPACE_NAME)_ListConcatenator_d7eb8485_9de8_4fc8_94fb_6eeeca68b2f37} ]
Tcl2 set $(FME_UUID_SAFE)__separator [FME_DecodeText {}];      regsub -all \"{}\" [FME_DecodeText {_list<opencurly><closecurly>._concatenated}] [FME_DecodeText {<opencurly><backslash>d+<closecurly>}] $(FME_UUID_SAFE)__listPattern;      set $(FME_UUID_SAFE)__listPattern ^$$(FME_UUID_SAFE)__listPattern$;
Tcl2 proc $(FME_UUID_SAFE)__Concatenate {} {   upvar \#0 $(FME_UUID_SAFE)__separator separator             $(FME_UUID_SAFE)__listPattern listPattern;   set allAttrs [lsort -dictionary [FME_AttributeNames]];   set keepEmptyParts [string equal {No} {No}];   set result {};   foreach attrName $allAttrs {     if {[regexp $listPattern $attrName]} {       set attrValue [FME_GetAttribute $attrName];       if {$keepEmptyParts || $attrValue != {}} {         lappend result $attrValue;       };     };   };   FME_SetAttribute [FME_DecodeText {"UNIQUE<space>VALUES"}] [join $result $separator]; }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(UniqueValueLogger_WORKSPACE_NAME)_ListConcatenator }    INPUT  FEATURE_TYPE "$(UniqueValueLogger_WORKSPACE_NAME)_ListBuilder_OUTPUT"    OUTPUT { FEATURE_TYPE "$(UniqueValueLogger_WORKSPACE_NAME)_ListConcatenator_OUTPUT"         @Tcl2($(FME_UUID_SAFE)__Concatenate)          }
# -------------------------------------------------------------------------
DEFAULT_MACRO $(UniqueValueLogger_WORKSPACE_NAME)_StringConcatenator_2_e484da63_c93d_4542_9f3c_0f24e69174387_ATTRS_TO_EVALUATE
INCLUDE [    if {{OUTGOING} == {OUTGOING}} {       if {[string length {UNIQUE<space>VALUES}] == 0} { return; };       set attrs [list {UNIQUE<space>VALUES}];    } else {       set attrs [split {<Unused>} { }];    };    set clauses {};    foreach attr $attrs {       lappend clauses "ATTR";       lappend clauses "{";       lappend clauses $attr;       lappend clauses {"<lf><lf>VALUE<comma><space>COUNT<lf><at>Value<openparen>UNIQUE<space>VALUES<closeparen><lf>"};       lappend clauses "}";    };    puts "MACRO $(UniqueValueLogger_WORKSPACE_NAME)_StringConcatenator_2_e484da63_c93d_4542_9f3c_0f24e69174387_ATTRS_TO_EVALUATE [join $clauses { }]"; ]
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { $(UniqueValueLogger_WORKSPACE_NAME)_StringConcatenator_2 }    INPUT  FEATURE_TYPE "$(UniqueValueLogger_WORKSPACE_NAME)_ListConcatenator_OUTPUT"    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    $($(UniqueValueLogger_WORKSPACE_NAME)_StringConcatenator_2_e484da63_c93d_4542_9f3c_0f24e69174387_ATTRS_TO_EVALUATE)    OUTPUT { OUTPUT FEATURE_TYPE "$(UniqueValueLogger_WORKSPACE_NAME)_StringConcatenator_2_OUTPUT"        }
# -------------------------------------------------------------------------
# Build the List removal function and regular expression if there was any list attributes to be removed.
# If not, then we will not have any extra list removal call to @RemoveAttributes, which speeds the
# normal, non-list removal especially when in Bulk Mode.  Note that this computation of the regular expressions is done
# once during mapping file parse time.
INCLUDE [    set listAttributeRemoveRegexps {};    set anyList {no};    foreach attr [split "_list<opencurly><closecurly>"] {       set attr [FME_DecodeText $attr];       set attr [regsub "{}$" $attr "{}.*"];       set attr [regsub -all "{}" $attr "\\{\[0-9\]+\\}"];       append listAttributeRemoveRegexps ",^$attr$";       set anyList {yes};    };    if { ${anyList} == {no} } {        puts {MACRO $(UniqueValueLogger_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC }    } else {        puts "MACRO $(UniqueValueLogger_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC @RemoveAttributes(fme_pcre_match\"$listAttributeRemoveRegexps\")"    }; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(UniqueValueLogger_WORKSPACE_NAME)_AttributeRemover_2 }    INPUT  FEATURE_TYPE "$(UniqueValueLogger_WORKSPACE_NAME)_StringConcatenator_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(UniqueValueLogger_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"        @RemoveAttributes(fme_encoded,)        $($(UniqueValueLogger_WORKSPACE_NAME)_AttributeRemover_2_LIST_FUNC)         }

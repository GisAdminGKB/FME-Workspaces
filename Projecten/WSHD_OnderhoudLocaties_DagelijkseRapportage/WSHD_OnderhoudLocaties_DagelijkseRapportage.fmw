ULTIPART_RESPONSE_HEADER_LIST_ATTR { "<Unused>" }    MINIMUM_ENCRYPTION_LEVEL { "OS_DEFAULT" }    CLIENT_CERTIFICATE_TYPE { "NONE" }    CLIENT_CERTIFICATE_FROM_OS { "<Unused>" }    CLIENT_CERTIFICATE_FILE { "<Unused>" }    CLIENT_CERTIFICATE_PRIVATE_KEY_FILE { "<Unused>" }    CLIENT_CERTIFICATE_PASSWORD { "<Unused>" }    OUTPUT { OUTPUT FEATURE_TYPE "$(GKB_EmailGenerator_WORKSPACE_NAME)_HTTPCaller_2_Output"          }    OUTPUT { REJECTED FEATURE_TYPE "$(GKB_EmailGenerator_WORKSPACE_NAME)_HTTPCaller_2_<REJECTED>"          }

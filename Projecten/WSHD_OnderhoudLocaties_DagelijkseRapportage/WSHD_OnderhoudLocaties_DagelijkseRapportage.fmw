FACTORY_DEF * TeeFactory   FACTORY_NAME "AGOL_GetToken_gisadmin_2 HTTPCaller_Input Input Collector"   INPUT FEATURE_TYPE AttributeCombiner_2_Output   OUTPUT FEATURE_TYPE AGOL_GetToken_gisadmin_2_HTTPCaller_Input
MACRO AGOL_GetToken_gisadmin_WORKSPACE_NAME AGOL_GetToken_gisadmin_2
MACRO $(AGOL_GetToken_gisadmin_WORKSPACE_NAME)_TRANSFORMER_GROUP 
MACRO $(AGOL_GetToken_gisadmin_WORKSPACE_NAME)_XFORMER_NAME AGOL_GetToken_gisadmin_2
MACRO $(AGOL_GetToken_gisadmin_WORKSPACE_NAME)_User gisadmin_GKB
MACRO $(AGOL_GetToken_gisadmin_WORKSPACE_NAME)_Password fme_decrypt()
MACRO $(AGOL_GetToken_gisadmin_WORKSPACE_NAME)_SUB_DOC_NAME AGOL_GetToken_gisadmin
MACRO $(AGOL_GetToken_gisadmin_WORKSPACE_NAME)_SUB_DOC_NAME AGOL_GetToken_gisadmin
DEFAULT_MACRO AGOL_GetToken_gisadmin_WORKSPACE_NAME ""
INCLUDE [puts {MACRO WB_OLD_CONTEXT_$(AGOL_GetToken_gisadmin_WORKSPACE_NAME) $(WB_CURRENT_CONTEXT)};          puts {MACRO WB_CURRENT_CONTEXT $(AGOL_GetToken_gisadmin_WORKSPACE_NAME)}]

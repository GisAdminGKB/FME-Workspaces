#!   IS_STAND_ALONE="true"
#! />
#! </GLOBAL_PARAMETERS>
#! <USER_PARAMETERS
#!   FORM=""
#! >
#! <PARAMETER_INFO>
#!     <INFO NAME="GROUP_BY" 
#!   DEFAULT_VALUE=""
#!   SCOPE="DEPENDENT"
#!   GENERATED_GUI_LINE="false"
#!   GUI_LINE="GUI LITERAL OPTIONAL ATTRLIST GROUP_BY &quot; &quot; Group By:"
#! />
#!     <INFO NAME="ORDERED_BY_GROUP" 
#!   DEFAULT_VALUE="No"
#!   SCOPE="STAND_ALONE"
#!   GENERATED_GUI_LINE="false"
#!   GUI_LINE="GUI LITERAL CHOICE ORDERED_BY_GROUP Yes%No Input is Ordered by Group:"
#! />
#!     <INFO NAME="ATTRS" 
#!   DEFAULT_VALUE=""
#!   SCOPE="STAND_ALONE"
#!   GENERATED_GUI_LINE="false"
#!   GUI_LINE="GUI LITERAL ATTRLIST ATTRS &quot; &quot; Attributes to Combine:"
#! />
#!     <INFO NAME="MAX_NUM" 
#!   DEFAULT_VALUE=""
#!   SCOPE="STAND_ALONE"
#!   GENERATED_GUI_LINE="false"
#!   GUI_LINE="GUI LITERAL OPTIONAL RANGE_SLIDER MAX_NUM &quot;RANGE:(0,]%PRECISION:0&quot; Maximum Number of Features to Combine:"
#! />
#!     <INFO NAME="DROP_EMPTY" 
#!   DEFAULT_VALUE="No"

INCLUDE [ FME_CleanseFMEUUID {$(UniqueValueLogger_WORKSPACE_NAME)_Logger_0a453cd2_2e66_438d_8491_b1f79ae01c127} ]
# If the Logger was in a custom transformer, the custom transformer's name was not being
# properly logged -- instead we saw "$(<customXformerName_WORKSPACE_NAME)" being logged as the prefix of the
# message. By deferencing and expanding out the XFORMER_NAME below, and then "WWJD" encoding it when it is
# used in the @Log call via the $encode macro name suffix trick, we get the right result, and the right result
# safely.
MACRO LOGGABLE_XFORMER_NAME $(UniqueValueLogger_WORKSPACE_NAME)_Logger
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { $(UniqueValueLogger_WORKSPACE_NAME)_Logger_Logger }    INPUT  FEATURE_TYPE "$(UniqueValueLogger_WORKSPACE_NAME)_AttributeRemover_2_OUTPUT"    OUTPUT { FEATURE_TYPE "$(UniqueValueLogger_WORKSPACE_NAME)_Logger_LOGGED"                  @Log(ENCODED, "$(LOGGABLE_XFORMER_NAME$encode):<space>Unique<space>values:","1","1","",INFO,LOG_RECORD,$(FME_UUID_SAFE))                   }
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(UniqueValueLogger_WORKSPACE_NAME)_Logger LOGGED Transformer Output Nuker"   INPUT FEATURE_TYPE "$(UniqueValueLogger_WORKSPACE_NAME)_Logger_LOGGED"

FACTORY_DEF * TeeFactory   FACTORY_NAME "TestFilter_2 Gerapporteerd Transformer Output Nuker"   INPUT FEATURE_TYPE TestFilter_2_Gerapporteerd
# -------------------------------------------------------------------------
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { TestFilter_InspectieType_INPUT }    INPUT  FEATURE_TYPE TestFilter_2_<at>Value<openparen>Gerapporteerd<closeparen><space>=<space>Nee<space>OR<space>Gewijzigd    OUTPUT { FEATURE_TYPE TestFilter_InspectieType_INPUTLINE }
FACTORY_DEF {*} TestFactory FACTORY_NAME { TestFilter_InspectieType } INPUT FEATURE_TYPE TestFilter_InspectieType_INPUTLINE FEATURE_TABLE_SHIM_SUPPORT Yes PASSED_TEST_GROUP_OUTPUT FIRST TEST_GROUP TEST { @EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>InspectieType<closeparen>,TestFilter_InspectieType) = Storing ENCODED } BOOLEAN_OPERATOR OR COMPOSITE_TEST_EXPR "1" OUTPUT PASSED_0 FEATURE_TYPE TestFilter_InspectieType_InspectieType<space>=<space>Storing OUTPUT FAILED FEATURE_TYPE TestFilter_InspectieType_InspectieType<space>=<space>Inspectie
FACTORY_DEF * TeeFactory   FACTORY_NAME "TestFilter_InspectieType InspectieType<space>=<space>Storing Splitter"   INPUT FEATURE_TYPE TestFilter_InspectieType_InspectieType<space>=<space>Storing   OUTPUT FEATURE_TYPE TestFilter_InspectieType_InspectieType<space>=<space>Storing_0_i/lusloORfw=   OUTPUT FEATURE_TYPE TestFilter_InspectieType_InspectieType<space>=<space>Storing_1_lmbxaai0COo=
FACTORY_DEF * TeeFactory   FACTORY_NAME "TestFilter_InspectieType InspectieType<space>=<space>Inspectie Splitter"   INPUT FEATURE_TYPE TestFilter_InspectieType_InspectieType<space>=<space>Inspectie   OUTPUT FEATURE_TYPE TestFilter_InspectieType_InspectieType<space>=<space>Inspectie_0_OoPN2p0OQPA=   OUTPUT FEATURE_TYPE TestFilter_InspectieType_InspectieType<space>=<space>Inspectie_1_Qy93wPc7Skg=

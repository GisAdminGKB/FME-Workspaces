#!   DEFAULT_VALUE="&lt;comma&gt;"
#!   IS_STAND_ALONE="true"
#! />
#! <GLOBAL_PARAMETER
#!   GUI_LINE="GUI LITERAL LOOKUP_CHOICE QUOT Single&lt;space&gt;Quotation&lt;space&gt;Marks:&lt;space&gt;&lt;apos&gt;value&lt;apos&gt;,Single%Double&lt;space&gt;Quotation&lt;space&gt;Marks:&lt;space&gt;&lt;quote&gt;value&lt;quote&gt;,Double%Round&lt;space&gt;Brackets:&lt;space&gt;&lt;openparen&gt;value&lt;closeparen&gt;,Round%Curly&lt;space&gt;Brackets:&lt;space&gt;&lt;opencurly&gt;value&lt;closecurly&gt;,Curly%Square&lt;space&gt;Brackets:&lt;space&gt;&lt;openbracket&gt;value&lt;closebracket&gt;,Square%Inequality&lt;space&gt;Signs:&lt;space&gt;&lt;lt&gt;value&lt;gt&gt;,Inequality%None,None Surround Each Value With:"
#!   DEFAULT_VALUE="None"
#!   IS_STAND_ALONE="true"
#! />
#! <GLOBAL_PARAMETER
#!   GUI_LINE="GUI LITERAL OPTIONAL TEXT_EDIT PREFIX &quot; &quot; Prefix for Each Value:"
#!   DEFAULT_VALUE=""
#!   IS_STAND_ALONE="true"
#! />

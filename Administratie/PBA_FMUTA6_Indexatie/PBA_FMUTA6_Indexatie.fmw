DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME FeatureMerger_FMUTA6_Schema_<Rejected> INPUT FEATURE_TYPE FeatureMerger_FMUTA6_Schema_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, FeatureMerger_FMUTA6_Schema<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Log<space>and<space>Troubleshoot<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)
# -------------------------------------------------------------------------
Tcl2    regsub {^[^a-zA-Z]*([a-zA-Z]).*} {.2f} {\1} formatChar;    if { [string first $formatChar {duiofxeEgG}] != -1 } {       proc {StringFormatter_bedragen_getAttribute} {attr} { return [regsub {^(-?)0*(.)} [FME_GetAttribute $attr] {\1\2}] }    }    else    {       proc {StringFormatter_bedragen_getAttribute} {attr} { return [FME_GetAttribute $attr] }    }
Tcl2 proc StringFormatter_bedragen_formatter {} {    set attrs [split {"BTW bedrag regel",Bedrag,Aantal,Tarief} {,}];    foreach attr $attrs {       set attrVal [FME_GetAttribute $attr];       set length [string length $attrVal];       if {$length > 0} {          if {[catch {             FME_SetAttribute $attr [format %.2f [{StringFormatter_bedragen_getAttribute} $attr]];          } result]} {             return 1          }       };    };    return 0 }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { StringFormatter_bedragen  }    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    INPUT  FEATURE_TYPE FeatureMerger_FMUTA6_Schema_MERGED    TEST @Tcl2(StringFormatter_bedragen_formatter) == 0    OUTPUT { FAILED FEATURE_TYPE StringFormatter_bedragen_<REJECTED>       @SupplyAttributes(fme_rejection_code, FORMATTER_ERROR)        }    OUTPUT { PASSED FEATURE_TYPE StringFormatter_bedragen_OUTPUT        }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
FACTORY_DEF * TeeFactory FACTORY_NAME StringFormatter_bedragen_<Rejected> INPUT FEATURE_TYPE StringFormatter_bedragen_<REJECTED>  NO_LOGGING   OUTPUT FAILED FEATURE_TYPE * @Abort(ENCODED, StringFormatter_bedragen<space>output<space>a<space><lt>Rejected<gt><space>feature.<space><space>To<space>continue<space>translation<space>when<space>features<space>are<space>rejected<comma><space>change<space><apos>Workspace<space>Parameters<apos><space><gt><space>Log<space>and<space>Troubleshoot<space><gt><space><apos>Rejected<space>Feature<space>Handling<apos><space>to<space><apos>Continue<space>Translation<apos>)

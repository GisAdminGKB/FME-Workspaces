FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { AttributeCreator_html_10 }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT  FEATURE_TYPE AttributeCombiner_4_Output    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "html_content" "SET_TO" "<lt>h5<gt><lt>font<space>color=red<gt>Ontbrekende<space>bonnen<space>bij<space>facturen.<lt><solidus>font<gt><space>De<space>export<space>van<space>de<space>bonnen<space>is<space>niet<space>compleet.<space>Er<space>zijn<space>factuurregels<space>waarbij<space>de<space>boninformatie<space>niet<space>gevonden<space>kan<space>worden.<lt><solidus>h4<gt><lf><lt>table<space>border=1<gt><lf><space><space><space><lt>thead<gt><lf><space><space><space><space><space><space><lt>tr<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>Factuur<lt><solidus>th<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>Factuurrun<lt><solidus>th<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>Bon<lt><solidus>th<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>Datum<lt><solidus>th<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>Artikel<lt><solidus>th<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>Hvh<lt><solidus>th<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>Eenheid<lt><solidus>th<gt><lf><space><space><space><space><space><space><lt><solidus>tr<gt><lf><space><space><space><lt><solidus>thead<gt><lf><space><space><space><lt>tbody<gt><lf><at>Value<openparen>html_artikelen<closeparen><lf><space><space><space><lt><solidus>tbody<gt><lf><lt><solidus>table<gt><lf>" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "Volgorde" "SET_TO" "1" "uint8" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeCreator_html_10_OUTPUT        }

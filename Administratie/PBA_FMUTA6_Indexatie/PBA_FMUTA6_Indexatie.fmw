DEFAULT_MACRO RESULT_DATETIME
DEFAULT_MACRO RESULT
DEFAULT_MACRO DateTimeCalculator_2_EXPRESSION expression
DEFAULT_MACRO DateTimeCalculator_2_RESULT_ATTR attr
INCLUDE [    proc stripEvaluateExpression {val} {       if {[regexp {@EvaluateExpression\([^)]*STRING_ENCODED,([^,]*),.+\)} $val -> unwrapped] && [string first {FME_CONDITIONAL:} $unwrapped] < 0}  {          return $unwrapped       } else {          return $val       };    }; ]
INCLUDE [    set start_datetime_stripped [stripEvaluateExpression {@EvaluateExpression(FDIV,STRING_ENCODED,<at>Value<openparen>_timestamp<closeparen>,DateTimeCalculator_2)}];    set end_datetime_stripped [stripEvaluateExpression {<Unused>}];    set years_stripped [stripEvaluateExpression {0}];    set months_stripped [stripEvaluateExpression {0}];    set days_stripped [stripEvaluateExpression {0}];    set hours_stripped [stripEvaluateExpression {1}];    set minutes_stripped [stripEvaluateExpression {0}];    set seconds_stripped [stripEvaluateExpression {0}];    set iso_interval_stripped [stripEvaluateExpression {<Unused>}];    set result_type_stripped [stripEvaluateExpression {<Unused>}];    set expression {};    set result_attr {};    if { "DATETIMECALC_1_ADD_INTERVAL" eq "DATETIMECALC_1_ADD_INTERVAL" ||         "DATETIMECALC_1_ADD_INTERVAL" eq "DATETIMECALC_2_ADD_ISO_INTERVAL" } {       set interval $iso_interval_stripped;       if { "DATETIMECALC_1_ADD_INTERVAL" eq "DATETIMECALC_1_ADD_INTERVAL" } {          set interval <at>DateTimeIntervalCreate<openparen><quote>$years_stripped<quote><comma><quote>$months_stripped<quote><comma><quote>$days_stripped<quote><comma><quote>$hours_stripped<quote><comma><quote>$minutes_stripped<quote><comma><quote>$seconds_stripped<quote><closeparen>;       };       set signed_interval $interval;       if { "ADD" eq "SUBTRACT" } {          set signed_interval <at>DateTimeIntervalNegate<openparen><quote>$interval<quote><closeparen>;       };       set result_attr {_result_datetime};       set expression <at>DateTimeAdd<openparen><quote>$start_datetime_stripped<quote><comma><quote>$signed_interval<quote><closeparen>;    } elseif { "DATETIMECALC_1_ADD_INTERVAL" eq "DATETIMECALC_3_CALCULATE_INTERVAL" } {       set result_attr {<Unused>};       set expression <at>DateTimeDiff<openparen><quote>$end_datetime_stripped<quote><comma><quote>$start_datetime_stripped<quote><comma><quote>$result_type_stripped<quote><closeparen>;    } elseif { "DATETIMECALC_1_ADD_INTERVAL" eq "DATETIMECALC_4_EXPRESSION" } {       set result_attr {<Unused>};       set expression {<Unused>};    };    puts "MACRO DateTimeCalculator_2_EXPRESSION $expression";    puts "MACRO DateTimeCalculator_2_RESULT_ATTR $result_attr"; ]
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { DateTimeCalculator_2_1 }    INPUT  FEATURE_TYPE DateTimeStamper_2_OUTPUT    OUTPUT { FEATURE_TYPE __TEST_NULL__       @EvaluateExpression(ATTR_CREATE_EXPR_PROPAGATE_MISSING_FDIV,$(DateTimeCalculator_2_RESULT_ATTR),"$(DateTimeCalculator_2_EXPRESSION)",DateTimeCalculator_2) }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { DateTimeCalculator_2_2 }    INPUT FEATURE_TYPE __TEST_NULL__    TEST { "$(DateTimeCalculator_2_RESULT_ATTR)" ATTRIBUTE_VALUE_NULL "" ENCODED }    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    OUTPUT { PASSED FEATURE_TYPE DateTimeCalculator_2_<REJECTED>       fme_rejection_code "INVALID_INPUT"       @RemoveAttributes("$(DateTimeCalculator_2_RESULT_ATTR)")        }    OUTPUT { FAILED FEATURE_TYPE DateTimeCalculator_2_OUTPUT        }

MACRO FME_VIEWER_APP fmedatainspector
DEFAULT_MACRO WB_CURRENT_CONTEXT
# -------------------------------------------------------------------------
Tcl2 proc Creator_CoordSysRemover {} {   global FME_CoordSys;   set FME_CoordSys {}; }
MACRO Creator_XML     NOT_ACTIVATED
MACRO Creator_GEOJSON NOT_ACTIVATED
INCLUDE [ if { {Geometry Object} == {Geometry Object} } {            puts {MACRO Creator_XML *} } ]
INCLUDE [ if { {Geometry Object} == {GeoJSON} } {            puts {MACRO Creator_GEOJSON *} } ]
FACTORY_DEF {$(Creator_XML)} CreationFactory    FACTORY_NAME { Creator_XML_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______        @Geometry(FROM_ENCODED_STRING,<lt>?xml<space>version=<quote>1.0<quote><space>encoding=<quote>US_ASCII<quote><space>standalone=<quote>no<quote><space>?<gt><lt>geometry<space>dimension=<quote>2<quote><gt><lt>null<solidus><gt><lt><solidus>geometry<gt>) }
FACTORY_DEF {$(Creator_GEOJSON)} CreationFactory    FACTORY_NAME { Creator_GEOJSON_Creator }    CREATE_AT_END { no }    OUTPUT { FEATURE_TYPE _____CREATED______ 	   @SupplyAttributes(ENCODED,__GeoJSONCreatorTemp__,<Unused>)        @JSONGeometry(FROM_ATTRIBUTE,GEOJSON,__GeoJSONCreatorTemp__, PREFER_ERROR_OVER_REJECTION) 	   @RemoveAttributes(__GeoJSONCreatorTemp__) }
FACTORY_DEF {*} TeeFactory    FACTORY_NAME { Creator_Cloner }    INPUT FEATURE_TYPE _____CREATED______        @Tcl2(Creator_CoordSysRemover)        @CoordSys()    NUMBER_OF_COPIES { 1 }    COPY_NUMBER_ATTRIBUTE { "_creation_instance" }    OUTPUT { FEATURE_TYPE Creator_CREATED        fme_feature_type Creator         }
FACTORY_DEF * BranchingFactory   FACTORY_NAME "Creator_CREATED Brancher -1 482"   INPUT FEATURE_TYPE Creator_CREATED   TARGET_FACTORY "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   MAXIMUM_COUNT None   OUTPUT PASSED FEATURE_TYPE *
# -------------------------------------------------------------------------
FACTORY_DEF * TeeFactory   FACTORY_NAME "$(WB_CURRENT_CONTEXT)_CREATOR_BRANCH_TARGET"   INPUT FEATURE_TYPE *  OUTPUT FEATURE_TYPE *
# -------------------------------------------------------------------------
FACTORY_DEF {CONNECTED} CreationFactory    FACTORY_NAME { AttributeCreator_paden_Creator }    OUTPUT { FEATURE_TYPE AttributeCreator_paden_____CREATED______ }
FACTORY_DEF {*} AttrSetFactory    FACTORY_NAME { AttributeCreator_paden }    COMMAND_PARM_EVALUATION SINGLE_PASS    INPUT { FEATURE_TYPE AttributeCreator_paden_____CREATED______ }    INPUT  FEATURE_TYPE Creator_CREATED    MULTI_FEATURE_MODE { NO }    NULL_ATTR_MODE { NO_OP }    ATTRSET_CREATE_DIRECTIVES _PROPAGATE_MISSING_FDIV    NUM_OF_COLUMNS 5    ATTR_ACTION { "" "data_dir" "SET_TO" "$(FME_SHAREDRESOURCE_DATA$encode)<backslash>Grondbank<backslash>FMUTA6" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "IndexatieBestand" "SET_TO" "<at>Value<openparen>data_dir<closeparen><backslash>GBY_Indexatie.xlsx" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "CSV_Schema" "SET_TO" "<at>Value<openparen>data_dir<closeparen><backslash>FMUTA6_Schema.csv" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "_url_get_artikelen" "SET_TO" "https:<solidus><solidus>fme-gkb.fmecloud.com<solidus>api<solidus>IndexatieGrondbank<solidus>indexatie_artikelen?DEBUG=NO" "varchar<openparen>80<closeparen>" }      ATTR_ACTION { "" "_url_get_indexaties" "SET_TO" "https:<solidus><solidus>fme-gkb.fmecloud.com<solidus>api<solidus>IndexatieGrondbank<solidus>indexaties?DEBUG=NO" "varchar<openparen>71<closeparen>" }      ATTR_ACTION { "" "_token_indexatie_API" "SET_TO" "c8fe3945982941066a1c4964d8a2ca5759e86c2b" "varchar<openparen>41<closeparen>" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeCreator_paden_OUTPUT        }

FACTORY_DEF * TeeFactory   FACTORY_NAME "AttributeCombiner_6 Input Input Collector"   INPUT FEATURE_TYPE AttributeCreator_html_13_OUTPUT   OUTPUT FEATURE_TYPE AttributeCombiner_6_Input
MACRO AttributeCombiner_WORKSPACE_NAME AttributeCombiner_6
MACRO $(AttributeCombiner_WORKSPACE_NAME)_TRANSFORMER_GROUP 

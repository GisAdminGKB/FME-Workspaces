FACTORY_DEF {*} TeeFactory    FACTORY_NAME { AttributeRounder_4_AttributeRounder }    INPUT FEATURE_TYPE __toOutput__    OUTPUT { FEATURE_TYPE AttributeRounder_4_OUTPUT         @Tcl2("AttributeRounder_4_round {2}")          }

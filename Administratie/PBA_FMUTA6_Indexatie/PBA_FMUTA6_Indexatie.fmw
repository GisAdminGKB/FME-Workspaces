MACRO $(AttributeCombiner_WORKSPACE_NAME)_ATTRS html_content
MACRO $(AttributeCombiner_WORKSPACE_NAME)_MAX_NUM 
MACRO $(AttributeCombiner_WORKSPACE_NAME)_DROP_EMPTY No

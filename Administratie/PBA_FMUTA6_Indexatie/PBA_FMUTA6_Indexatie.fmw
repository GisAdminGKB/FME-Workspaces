<space><lt>th<gt>Productgroep<lt><solidus>th<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>Week<lt><solidus>th<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>#Facturen<lt><solidus>th<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>#Bonregels<lt><solidus>th<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>#Artikelregels<lt><solidus>th<gt><lf><space><space><space><space><space><space><space><space><space><lt>th<gt>#Indexatieregels<lt><solidus>th<gt><lf><space><space><space><space><space><space><lt><solidus>tr<gt><lf><space><space><space><lt><solidus>thead<gt><lf><space><space><space><lt>tbody<gt><lf><at>Value<openparen>html_aantallen<closeparen><lf><space><space><space><lt><solidus>tbody<gt><lf><lt><solidus>table<gt>" "varchar<openparen>200<closeparen>" }      ATTR_ACTION { "" "Volgorde" "SET_TO" "31" "uint8" }    OUTPUT { OUTPUT FEATURE_TYPE AttributeCreator_html_5_OUTPUT        }

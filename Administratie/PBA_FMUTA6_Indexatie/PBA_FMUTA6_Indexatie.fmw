Tcl2    regsub {^[^a-zA-Z]*([a-zA-Z]).*} {.2f} {\1} formatChar;    if { [string first $formatChar {duiofxeEgG}] != -1 } {       proc {StringFormatter_bedragen_getAttribute} {attr} { return [regsub {^(-?)0*(.)} [FME_GetAttribute $attr] {\1\2}] }    }    else    {       proc {StringFormatter_bedragen_getAttribute} {attr} { return [FME_GetAttribute $attr] }    }
Tcl2 proc StringFormatter_bedragen_formatter {} {    set attrs [split {"BTW bedrag regel",Bedrag,Aantal,Tarief} {,}];    foreach attr $attrs {       set attrVal [FME_GetAttribute $attr];       set length [string length $attrVal];       if {$length > 0} {          if {[catch {             FME_SetAttribute $attr [format %.2f [{StringFormatter_bedragen_getAttribute} $attr]];          } result]} {             return 1          }       };    };    return 0 }
FACTORY_DEF {*} TestFactory    FACTORY_NAME { StringFormatter_bedragen  }    PRESERVE_FEATURE_ORDER PER_OUTPUT_PORT    INPUT  FEATURE_TYPE FeatureMerger_FMUTA6_Schema_MERGED    TEST @Tcl2(StringFormatter_bedragen_formatter) == 0    OUTPUT { FAILED FEATURE_TYPE StringFormatter_bedragen_<REJECTED>       @SupplyAttributes(fme_rejection_code, FORMATTER_ERROR)        }    OUTPUT { PASSED FEATURE_TYPE StringFormatter_bedragen_OUTPUT        }
DEFAULT_MACRO _WB_BYPASS_TERMINATION No
